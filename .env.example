# ScreenMind Configuration
# Copy this to .env and adjust as needed

# Capture Settings
CAPTURE_INTERVAL=30
SCREENSHOT_QUALITY=70
DATA_DIR=~/.screenmind

# Model Settings
GEMMA_MODE=local
OLLAMA_MODEL=gemma4:e2b
OLLAMA_HOST=http://localhost:11434

# Google AI Studio (fallback)
# GOOGLE_API_KEY=your-key-here

# Developer Context
WORKSPACE_DIRS=~/Projects,~/Desktop

# Privacy
BLOCKED_APPS=

# Hotkey
BOOKMARK_HOTKEY=ctrl+shift+b
